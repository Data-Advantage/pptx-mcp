{
  "name": "pptx-mcp",
  "version": "0.1.0",
  "description": "Official Model Context Protocol server for pptx.dev — generate, parse, validate, and render presentations through the pptx.dev REST API.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pptx-mcp": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "start": "node dist/cli.js",
    "verify": "node scripts/verify.mjs",
    "prepublishOnly": "pnpm run clean && pnpm run build && pnpm run verify"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Data-Advantage/pptx-mcp.git"
  },
  "homepage": "https://pptx.dev/mcp",
  "bugs": {
    "url": "https://github.com/Data-Advantage/pptx-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "pptx",
    "powerpoint",
    "presentations",
    "ai-agents"
  ]
}
