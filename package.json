{
  "name": "pptx-mcp",
  "version": "0.1.0",
  "description": "Stdio MCP server for pptx.dev — thin proxy to the remote streamable-HTTP server at mcp.pptx.dev.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "pptx-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Data-Advantage/pptx-mcp.git"
  },
  "homepage": "https://pptx.dev/mcp",
  "bugs": {
    "url": "https://github.com/Data-Advantage/pptx-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "pptx",
    "powerpoint",
    "presentations",
    "ai-agents"
  ]
}
